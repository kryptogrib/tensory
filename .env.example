# ══════════════════════════════════════════════════════════════
# tensory — environment variables
# Copy to .env and fill in your values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── OpenAI (embeddings + LLM extraction) ─────────────────────
# Required for: OpenAIEmbedder, openai_llm()
OPENAI_API_KEY=

# ── Anthropic (LLM extraction) ───────────────────────────────
# Required for: anthropic_llm(), anthropic_from_env()
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
# Proxy URL (e.g. CLIProxyAPI as in openHunter)
ANTHROPIC_BASE_URL=

# ── Model selection ──────────────────────────────────────────
# Used by anthropic_from_env() for LLM extraction
TENSORY_MODEL=claude-haiku-4-5-20251001
