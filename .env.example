# ══════════════════════════════════════════════════════════════
# tensory — environment variables
# Copy to .env and fill in your values:  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── OpenAI (embeddings + LLM extraction) ─────────────────────
# Required for: OpenAIEmbedder, openai_llm()
OPENAI_API_KEY=

# ── Anthropic (LLM extraction) — choose ONE option: ─────────
#
#   Option 1: Direct API
#     ANTHROPIC_API_KEY=sk-ant-...
#
#   Option 2: Via proxy (CLIProxyAPI, etc.)
#     ANTHROPIC_BASE_URL=http://localhost:8317
#     ANTHROPIC_API_KEY=signal-hunter-local
#
#   Option 3: Claude Code SDK (no API key needed)
#     ANTHROPIC_BASE_URL=claude-code
#     Requires: pip install tensory[claude-code]
#     Uses OAuth from `claude auth login` (Claude Pro/Max subscription)
#
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# ── Model selection ──────────────────────────────────────────
# Used by anthropic_from_env() for LLM extraction
TENSORY_MODEL=claude-haiku-4-5-20251001
